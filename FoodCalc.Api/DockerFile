# syntax=docker/dockerfile:1

# ---- Build stage ----
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# Copy every csproj first so `restore` is cached independently of source changes.
# API -> Features -> (DTOs, Persistence -> ServiceDefaults)
COPY ["FoodCalc.Api/FoodCalc.Api.csproj", "FoodCalc.Api/"]
COPY ["FoodCalc.Features/FoodCalc.Features.csproj", "FoodCalc.Features/"]
COPY ["FoodHub.DTOs/FoodHub.DTOs.csproj", "FoodHub.DTOs/"]
COPY ["FoodHub.Persistence/FoodHub.Persistence.csproj", "FoodHub.Persistence/"]
COPY ["FoodHub.ServiceDefaults/FoodHub.ServiceDefaults.csproj", "FoodHub.ServiceDefaults/"]

RUN dotnet restore "FoodCalc.Api/FoodCalc.Api.csproj"

# Copy the rest of the source and publish. NB: no --no-restore here — on .NET 10
# a csproj-only restore + --no-restore can drop framework static web assets from
# the publish. The earlier restore still warms the NuGet cache, so this is fast.
COPY . .
RUN dotnet publish "FoodCalc.Api/FoodCalc.Api.csproj" -c Release -o /app/publish

# ---- Runtime stage ----
FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS final
WORKDIR /app
COPY --from=build /app/publish .

EXPOSE 8080
ENV ASPNETCORE_URLS=http://+:8080
ENTRYPOINT ["dotnet", "FoodCalc.Api.dll"]

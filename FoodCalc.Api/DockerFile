# Build stage
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

# Copy solution and project files
COPY ["FoodCalc.Api/FoodCalc.Api.csproj", "FoodCalc.Api/"]
COPY ["FoodCalc.Features/FoodCalc.Features.csproj", "FoodCalc.Features/"]
COPY ["FoodHub.DTOs/FoodHub.DTOs.csproj", "FoodHub.DTOs/"]
COPY ["FoodHub.ServiceDefaults/FoodHub.ServiceDefaults.csproj", "FoodHub.ServiceDefaults/"]

# Copy the rest of the source code
COPY . .

# Restore, build, publish
WORKDIR /src/FoodCalc.Api
RUN dotnet restore
RUN dotnet publish "FoodCalc.Api.csproj" -c Release -o /app/publish

# Runtime stage
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS final
WORKDIR /app
COPY --from=build /app/publish .
EXPOSE 443
ENV ASPNETCORE_URLS=http://+:443
ENTRYPOINT ["dotnet", "FoodCalc.Api.dll"]

@page "/recepts/add"
@inject HttpClient Http

<PageTitle>Add Recept</PageTitle>

<h3>Add Recept</h3>

<EditForm FormName="CreateRecept" Model="_recept" OnValidSubmit="HandleValidSubmit">
    <div class="mb-3">
        <label for="name" class="form-label">Name</label>
        <InputText id="name" class="form-control" @bind-Value="_recept.Name" />
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger">@_errorMessage</div>
    }

    <button type="submit" class="btn btn-primary">Add Recept</button>
</EditForm>

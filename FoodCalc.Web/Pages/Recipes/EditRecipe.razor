@page "/recipes/edit/{RecipeId:guid}"
@inject RecipeService RecipeService
@inject IngredientService IngredientService
@inject AuthStateService AuthStateService
@inject NavigationManager Navigation

<PageTitle>Edit Recipe</PageTitle>

<div class="fh-stack">
	<div class="recipe-name">
		@if (!isEditingName)
		{
			<h1 class="fh-heading">@recipe?.Name</h1>
			<IconButton Icon="pencil" Title="Edit recipe name" OnClick="() => isEditingName = true"/>
		}
		else
		{
			<EditForm Model="recipe" OnValidSubmit="SaveRecipeName" class="recipe-name__form"
			          FormName="edit-recipe-name">
				<InputText @bind-Value="recipe.Name" class="form-control"/>
				<AppButton Type="submit" Size="ButtonSize.Small" Icon="check-lg">Save</AppButton>
				<AppButton Variant="ButtonVariant.OutlineSecondary" Size="ButtonSize.Small" OnClick="CancelEditName">
					Cancel
				</AppButton>
			</EditForm>
		}
	</div>

	<div class="row g-4">
		<!-- Left: ingredient form -->
		<div class="col-md-6">
			<AppCard>
				<div class="fh-field">
					<label for="ingredientSearch" class="form-label">Search Ingredient</label>
					<div class="input-group">
						<input id="ingredientSearch"
						       class="form-control"
						       type="text"
						       placeholder="Type to search..."
						       @bind="ingredientSearch"
						       @bind:event="oninput"
						       @onfocus="() => dropdownOpen = true"
						       @onblur="OnDropdownBlur"
						       autocomplete="off"
						       @onkeydown="HandleIngredientSearchKeydown"
						       @onkeydown:preventDefault="@(ingredientSearchFocused)"/>
						<button class="btn btn-outline-success" type="button" title="Add new ingredient"
						        @onclick="AddIngredient">
							<i class="bi bi-plus-lg" aria-hidden="true"></i>
						</button>
					</div>
				</div>

				<EditForm Model="recipeItem" OnValidSubmit="AddOrUpdateIngredient"
				          FormName="add-or-update-ingredient-form">
					<div class="ingredient-dropdown">
						<div class="ingredient-dropdown__menu dropdown-menu @(dropdownOpen ? "show" : null)">
							@foreach (var ingredient in FilteredIngredients)
							{
								<button type="button"
								        class="dropdown-item @(recipeItem.Name == ingredient.Name ? "active" : "")"
								        @onclick="() => SelectIngredient(ingredient)">
									@ingredient.Name
								</button>
							}
							@if (!FilteredIngredients.Any()) { <div class="dropdown-item disabled">No ingredients found.
								Click + to add.
							</div> }
						</div>
					</div>

					<NumberField TValue="decimal?" Label="Amount" @bind-Value="amountInput"/>

					<SelectField TValue="IngredientAmountTypeDto" Label="Amount Type"
					             @bind-Value="recipeItem.IngredientAmount">
						@foreach (IngredientAmountTypeDto amountType in Enum.GetValues<IngredientAmountTypeDto>())
						{
							<option value="@amountType">@amountType</option>
						}
					</SelectField>

					<div class="fh-cluster">
						<AppButton Type="submit" Icon="check-lg">Add/Save</AppButton>
						<AppButton Variant="ButtonVariant.OutlinePrimary" OnClick="ClearForm">Clear</AppButton>
					</div>
				</EditForm>
			</AppCard>
		</div>

		<!-- Right: current ingredients -->
		<div class="col-md-6">
			@if (recipe?.Ingredients is
				     {
					     Count: > 0
				     } ingredientsList)
			{
				<ul class="ingredient-list">
					@foreach (var ingredient in ingredientsList)
					{
						<li>
                            <span>
                                @ingredient.Name
	                            <span
		                            class="fh-muted">@ingredient.Amount.ToFormattedString() @ingredient.IngredientAmount</span>
                            </span>
							<span class="ingredient-list__actions">
                                <IconButton Icon="pencil" Title="Edit ingredient" Size="ButtonSize.Small"
                                            OnClick="() => EditIngredient(ingredient)"/>
                                <IconButton Icon="trash" Title="Delete ingredient" Size="ButtonSize.Small"
                                            Variant="ButtonVariant.Danger"
                                            OnClick="() => DeleteIngredient(ingredient.Id)"/>
                            </span>
						</li>
					}
				</ul>
			}
			else
			{
				<EmptyState Icon="basket" Title="No ingredients yet."
				            Message="Search or add an ingredient on the left to build this recipe."/>
			}
		</div>
	</div>
</div>

@code {

	[Parameter]
	public Guid RecipeId { get; set; }

	private RecipeDto recipe = new();
	private List<IngredientDto> ingredients = new();
	private RecipeItemDto recipeItem = new();
	private bool isEditingName = false;
	private string ingredientSearch = string.Empty;

	private IEnumerable<IngredientDto> FilteredIngredients => string.IsNullOrWhiteSpace(ingredientSearch) ? ingredients : ingredients.Where(i => i.Name.Contains(ingredientSearch, StringComparison.OrdinalIgnoreCase));

	private decimal? amountInput;
	private bool dropdownOpen = false;
	private bool ingredientSearchFocused = false;

	protected override async Task OnInitializedAsync()
	{
		if (!await AuthStateService.IsInAnyRoleAsync("Admin"))
		{
			Navigation.NavigateTo("/");
			return;
		}

		recipe = await RecipeService.GetRecipeByIdAsync(RecipeId)
		                            .OrDefault<RecipeDto>(new());

		await IngredientService.GetAllIngredientsAsync()
		                       .OnSuccess((data) =>
		                       {
			                       ingredients = data;
			                       ClearForm();
		                       })
		                       .OnFailure();
	}

	private async Task RefreshRecipeAsync()
	{
		await RecipeService.GetRecipeByIdAsync(RecipeId)
		                   .OnSuccess((data) => recipe = data)
		                   .OnFailure();
	}

	private async Task AddOrUpdateIngredient()
	{
		recipeItem.RecipeId = RecipeId;
		recipeItem.Amount = amountInput ?? 0;

		await RecipeService.AddIngredient(recipeItem)
		                   .OnSuccess(message: WebConstants.Messages.Ingredient.AddedOrUpdated)
		                   .OnFailure();

		ClearForm();
		await RefreshRecipeAsync(); // Refresh the list
	}

	private void EditIngredient(RecipeItemDto ingredient)
	{
		recipeItem = new RecipeItemDto {Id = ingredient.Id, RecipeId = RecipeId, Name = ingredient.Name, Amount = ingredient.Amount, IngredientAmount = ingredient.IngredientAmount, ShouldBeAddedToShoppingCart = ingredient.ShouldBeAddedToShoppingCart};
		amountInput = ingredient.Amount == 0 ? null : ingredient.Amount;
		ingredientSearch = ingredient.Name;
	}

	private async Task DeleteIngredient(Guid recipeItemId)
	{
		await RecipeService.DeleteIngredient(recipeItemId)
		                   .OnSuccess(message: WebConstants.Messages.Ingredient.Deleted)
		                   .OnFailure();

		ClearForm();
		await RefreshRecipeAsync(); // Refresh the list
	}

	private void ClearForm()
	{
		ingredientSearch = string.Empty;
		amountInput = null;
		recipeItem = new RecipeItemDto {Id = Guid.NewGuid(), RecipeId = RecipeId};
	}

	private async Task SaveRecipeName()
	{
		await RecipeService.UpdateRecipeName(RecipeId, recipe.Name!)
		                   .OnSuccess(message: WebConstants.Messages.Recipe.NameUpdated)
		                   .OnFailure();

		isEditingName = false;
		await RefreshRecipeAsync(); // Refresh
	}

	private async Task AddIngredient()
	{
		await IngredientService.AddIngredientAsync(new CreateIngredientDto {Name = ingredientSearch})
		                       .OnSuccess(async () =>
		                       {
			                       await IngredientService.GetAllIngredientsAsync()
			                                              .OnSuccess((data) => ingredients = data)
			                                              .OnFailure();

			                       var created = ingredients.FirstOrDefault(i => i.Name == ingredientSearch);

			                       //only clear when failed
			                       if (created is not null)
			                       {
				                       recipeItem.Name = created.Name;
				                       recipeItem.ShouldBeAddedToShoppingCart = created.ShouldBeAddedToShoppingCart;
			                       }
			                       else { ingredientSearch = string.Empty; }
		                       }, WebConstants.Messages.Ingredient.Added)
		                       .OnFailure();
	}

	private void SelectIngredient(IngredientDto ingredient)
	{
		recipeItem.Name = ingredient.Name;
		recipeItem.ShouldBeAddedToShoppingCart = ingredient.ShouldBeAddedToShoppingCart;
		ingredientSearch = ingredient.Name;
		dropdownOpen = false;
	}

	private async Task OnDropdownBlur()
	{
		// Delay to allow click event to register before closing dropdown
		await Task.Delay(150);
		dropdownOpen = false;
	}

	private void CancelEditName() { isEditingName = false; }

	private async Task HandleIngredientSearchKeydown(KeyboardEventArgs e)
	{
		if (e.Key == "Enter") { await AddIngredient(); }
	}

}

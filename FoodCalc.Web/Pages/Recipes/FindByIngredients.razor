@page "/recipes/find"

@using Blazored.LocalStorage
@using FoodCalc.Web.Constants
@inject RecipeService recipeService
@inject IngredientService ingredientService
@inject ILocalStorageService LocalStorage
@inject NavigationManager NavigationManager

<PageTitle>Find recipes</PageTitle>

<div class="find-layout">
	<PageHeader Title="Find recipes"
	            Subtitle="Add the ingredients you have, then discover what you can cook."/>

	<div class="find-content">
		@* --- Left: ingredient list builder + settings --- *@
		<aside class="find-sidebar">
			<AppCard CssClass="find-panel">
				<Header>
					<span class="find-panel__title">
						<i class="bi bi-basket2" aria-hidden="true"></i> My ingredients
					</span>
				</Header>
				<Body>
				<div class="find-combo">
					<div class="find-add">
						<input type="text"
						       class="form-control"
						       placeholder="e.g. eggs, flour, tomato..."
						       aria-label="Add an ingredient"
						       autocomplete="off"
						       role="combobox"
						       aria-expanded="@showSuggestions"
						       value="@newIngredient"
						       @oninput="OnQueryInput"
						       @onfocus="ShowSuggestions"
						       @onblur="OnInputBlur"
						       @onkeydown="OnInputKeyDown"/>
						<AppButton Variant="ButtonVariant.Primary"
						           Icon="plus-lg"
						           Title="Add ingredient"
						           Disabled="@string.IsNullOrWhiteSpace(newIngredient)"
						           OnClick="AddCurrent"/>
					</div>

					@if (showSuggestions)
					{
						List<string> options = FilteredSuggestions;
						if (options.Count > 0 || !string.IsNullOrWhiteSpace(newIngredient))
						{
							<ul class="find-combo__menu" role="listbox">
								@for (int i = 0; i < options.Count; i++)
								{
									int index = i;
									string name = options[i];
									<li role="option"
									    aria-selected="@(index == activeIndex)"
									    class="find-combo__option @(index == activeIndex ? "is-active" : null)"
									    @onmousedown:preventDefault="true"
									    @onmousedown="() => SelectSuggestion(name)">
										<i class="bi bi-plus-circle" aria-hidden="true"></i>
										<span>@name</span>
									</li>
								}
								@if (options.Count == 0 && !string.IsNullOrWhiteSpace(newIngredient))
								{
									<li class="find-combo__option find-combo__option--new"
									    @onmousedown:preventDefault="true"
									    @onmousedown="AddCurrent">
										<i class="bi bi-plus-lg" aria-hidden="true"></i>
										<span>Add &ldquo;@newIngredient.Trim()&rdquo;</span>
									</li>
								}
							</ul>
						}
					}
				</div>

				@if (prefs.Ingredients.Count == 0)
				{
					<p class="find-hint fh-muted">
						Nothing added yet. Type an ingredient above and press Enter.
					</p>
				}
				else
				{
					<div class="find-chips">
						@foreach (string ingredient in prefs.Ingredients)
						{
							<span class="find-chip">
									<span class="find-chip__label" title="@ingredient">@ingredient</span>
									<button type="button"
									        class="find-chip__remove"
									        aria-label="@($"Remove {ingredient}")"
									        @onclick="() => RemoveIngredient(ingredient)">
										<i class="bi bi-x" aria-hidden="true"></i>
									</button>
								</span>
						}
					</div>
					<AppButton Variant="ButtonVariant.Link"
					           Size="ButtonSize.Small"
					           Icon="trash"
					           CssClass="find-clear"
					           OnClick="ClearIngredients">
						Clear all
					</AppButton>
				}
				</Body>
			</AppCard>

			<AppCard CssClass="find-panel">
				<Header>
					<span class="find-panel__title">
						<i class="bi bi-sliders" aria-hidden="true"></i> Options
					</span>
				</Header>
				<Body>
				<EditForm Model="prefs" FormName="find-options">
					<SelectField TValue="MatchMode"
					             Label="Match"
					             @bind-Value="prefs.Mode"
					             @bind-Value:after="PersistAndRecompute">
						<option value="@nameof(MatchMode.Any)">Contains any of my ingredients</option>
						<option value="@nameof(MatchMode.All)">Must contain all my ingredients</option>
					</SelectField>

					<SelectField TValue="SortMode"
					             Label="Sort by"
					             @bind-Value="prefs.Sort"
					             @bind-Value:after="PersistAndRecompute">
						<option value="@nameof(SortMode.MostMatches)">Most of my ingredients</option>
						<option value="@nameof(SortMode.FewestMissing)">Fewest missing ingredients</option>
						<option value="@nameof(SortMode.Name)">Name (A–Z)</option>
					</SelectField>

					<label class="find-check">
						<input type="checkbox"
						       class="form-check-input"
						       checked="@prefs.Highlight"
						       @onchange="OnHighlightChanged"/>
						<span>Highlight my ingredients in each recipe</span>
					</label>
				</EditForm>
				</Body>
			</AppCard>
		</aside>

		@* --- Right: results --- *@
		<section class="find-results">
			@if (allRecipes == null)
			{
				<LoadingSpinner Label="Loading recipes..."/>
			}
			else if (prefs.Ingredients.Count == 0)
			{
				<EmptyState Icon="basket"
				            Title="Add some ingredients"
				            Message="Build your ingredient list on the left to see matching recipes."/>
			}
			else if (results.Count == 0)
			{
				<EmptyState Icon="search"
				            Title="No matching recipes"
				            Message="@NoResultsMessage"/>
			}
			else
			{
				<p class="find-count fh-muted">
					@results.Count @(results.Count == 1 ? "recipe" : "recipes") found
				</p>
				<div class="fh-grid">
					@foreach (RecipeMatch match in results)
					{
						<div class="card find-card">
							<div class="find-card__header">
								<h5 class="card-title" title="@match.Recipe.Name">@match.Recipe.Name</h5>
							</div>
							<div class="badge-container">
								<Badge
									Variant="@(match.IsFullMatch ? Badge.BadgeVariant.Success : Badge.BadgeVariant.Accent)"
									Icon="check2-circle">
									@match.MatchedCount / @prefs.Ingredients.Count
								</Badge>
							</div>
							<div class="card-body">
								<ul class="find-ingredients">
									@foreach (RecipeItemDto ingredient in match.Recipe.Ingredients)
									{
										bool hit = prefs.Highlight && match.MatchedNames.Contains(ingredient.Name);
										<li class="@(hit ? "find-ingredients__hit" : null)">
											@if (hit) { <i class="bi bi-check-lg" aria-hidden="true"></i> }
											<span>@ingredient.Name</span>
											<span class="fh-muted find-ingredients__amount">
												@ingredient.Amount.ToFormattedString() @ingredient.IngredientAmount.ToString()
											</span>
										</li>
									}
								</ul>
							</div>
							<div class="find-card__footer">
								@if (match.MissingCount == 0)
								{
									<span class="fh-muted find-card__note">
										<i class="bi bi-bag-check" aria-hidden="true"></i> You have everything listed
									</span>
								}
								else
								{
									<span class="fh-muted find-card__note">
										@match.MissingCount more @(match.MissingCount == 1 ? "ingredient" : "ingredients") needed
									</span>
								}
								<AppButton Variant="ButtonVariant.OutlineSecondary"
								           Size="ButtonSize.Small"
								           Icon="box-arrow-up-right"
								           OnClick="() => OpenRecipe(match.Recipe.Id)">
									Open
								</AppButton>
							</div>
						</div>
					}
				</div>
			}
		</section>
	</div>
</div>

@code {
	private List<RecipeDto>? allRecipes;
	private List<string> knownIngredientNames = [];
	private List<RecipeMatch> results = [];
	private string newIngredient = string.Empty;
	private bool showSuggestions;
	private int activeIndex = -1;

	private Preferences prefs = new();

	protected override async Task OnInitializedAsync()
	{
		prefs = await LocalStorage.GetItemAsync<Preferences>(WebConstants.Storage.PantryPreferences) ?? new Preferences();

		allRecipes = await recipeService.GetAllRecipesAsync(withIngredients: true)
		                                .OrDefault(new List<RecipeDto>());

		// Known ingredient names power the type-ahead suggestions; failure here is non-fatal.
		var ingredients = await ingredientService.GetAllIngredientsAsync();
		if (ingredients.Success && ingredients.Data is not null)
			knownIngredientNames =
			[
				..ingredients.Data.Select(i => i.Name)
				             .Where(n => !string.IsNullOrWhiteSpace(n))
				             .Distinct()
			];

		Recompute();
	}

	/// <summary>
	/// Known ingredient names for the type-ahead: excludes anything already added and filters by
	/// the current query (case-insensitive substring). All matches are returned — the menu scrolls.
	/// </summary>
	private List<string> FilteredSuggestions
	{
		get
		{
			string query = newIngredient.Trim();
			return knownIngredientNames.Where(n => !prefs.Ingredients.Contains(n, StringComparer.OrdinalIgnoreCase))
			                           .Where(n => query.Length == 0 || n.Contains(query, StringComparison.OrdinalIgnoreCase))
			                           .OrderBy(n => n)
			                           .ToList();
		}
	}

	private string NoResultsMessage => prefs.Mode == MatchMode.All ? "No recipe contains all of those ingredients. Try switching Match to \"any\"." : "None of your ingredients appear in a recipe yet.";

	private void ShowSuggestions() => showSuggestions = true;

	private void OnQueryInput(ChangeEventArgs e)
	{
		newIngredient = e.Value?.ToString() ?? string.Empty;
		showSuggestions = true;
		activeIndex = -1;
	}

	private void OnInputBlur()
	{
		// Options select on mousedown with preventDefault, so they never steal focus from the input.
		// A real blur therefore means focus left the combobox entirely, so the menu can close.
		showSuggestions = false;
		activeIndex = -1;
	}

	private async Task OnInputKeyDown(KeyboardEventArgs e)
	{
		List<string> options = FilteredSuggestions;

		switch (e.Key)
		{
			case "ArrowDown":
				showSuggestions = true;
				if (options.Count > 0)
					activeIndex = (activeIndex + 1) % options.Count;
			break;
			case "ArrowUp":
				if (options.Count > 0)
					activeIndex = activeIndex <= 0 ? options.Count - 1 : activeIndex - 1;
			break;
			case "Enter":
				if (activeIndex >= 0 && activeIndex < options.Count)
					await SelectSuggestion(options[activeIndex]);
				else
					await AddCurrent();
			break;
			case "Escape":
				showSuggestions = false;
				activeIndex = -1;
			break;
		}
	}

	private Task SelectSuggestion(string name) => AddValue(name);

	private Task AddCurrent() => AddValue(newIngredient);

	private async Task AddValue(string value)
	{
		string trimmed = value.Trim();
		if (trimmed.Length == 0)
			return;

		if (!prefs.Ingredients.Contains(trimmed, StringComparer.OrdinalIgnoreCase))
			prefs.Ingredients.Add(trimmed);

		newIngredient = string.Empty;
		activeIndex = -1;
		// Keep the menu open so several ingredients can be added in a row — the input keeps focus
		// because option mousedown suppresses blur.
		showSuggestions = true;
		await PersistAndRecompute();
	}

	private async Task RemoveIngredient(string ingredient)
	{
		prefs.Ingredients.RemoveAll(i => string.Equals(i, ingredient, StringComparison.OrdinalIgnoreCase));
		await PersistAndRecompute();
	}

	private async Task ClearIngredients()
	{
		prefs.Ingredients.Clear();
		await PersistAndRecompute();
	}

	private async Task OnHighlightChanged(ChangeEventArgs e)
	{
		prefs.Highlight = e.Value is true;
		await LocalStorage.SetItemAsync(WebConstants.Storage.PantryPreferences, prefs);
		// Highlight only affects rendering, no re-match needed.
	}

	private void OpenRecipe(Guid recipeId) { NavigationManager.NavigateTo($"/recipe/{recipeId}"); }

	private async Task PersistAndRecompute()
	{
		await LocalStorage.SetItemAsync(WebConstants.Storage.PantryPreferences, prefs);
		Recompute();
	}

	/// <summary>
	/// Matches every recipe against the current ingredient list, then filters and sorts
	/// according to the chosen options. A recipe ingredient counts as a match when its
	/// name contains one of my terms (case-insensitive), so "egg" matches "Eggs".
	/// </summary>
	private void Recompute()
	{
		if (allRecipes is null)
			return;

		string[] terms =
		[
			..prefs.Ingredients.Select(i => i.Trim())
			       .Where(t => t.Length > 0)
		];
		var matches = new List<RecipeMatch>();

		foreach (RecipeDto recipe in allRecipes)
		{
			List<RecipeItemDto> recipeIngredients = recipe.Ingredients ?? [];
			var matchedNames = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
			int matchedTerms = 0;

			foreach (string term in terms)
			{
				bool termHit = false;
				foreach (RecipeItemDto ri in recipeIngredients)
				{
					if (ri.Name.Contains(term, StringComparison.OrdinalIgnoreCase))
					{
						matchedNames.Add(ri.Name);
						termHit = true;
					}
				}

				if (termHit)
					matchedTerms++;
			}

			int missing = recipeIngredients.Count(ri => !matchedNames.Contains(ri.Name));
			matches.Add(new RecipeMatch(recipe, matchedTerms, matchedNames, missing));
		}

		IEnumerable<RecipeMatch> filtered = prefs.Mode == MatchMode.All ? matches.Where(m => m.MatchedCount == terms.Length && terms.Length > 0) : matches.Where(m => m.MatchedCount > 0);

		results = [..Sort(filtered)];
	}

	private IEnumerable<RecipeMatch> Sort(IEnumerable<RecipeMatch> source) =>
		prefs.Sort switch
		{
			SortMode.FewestMissing => source.OrderBy(m => m.MissingCount)
			                                .ThenByDescending(m => m.MatchedCount)
			                                .ThenBy(m => m.Recipe.Name),
			SortMode.Name => source.OrderBy(m => m.Recipe.Name),
			_ => source.OrderByDescending(m => m.MatchedCount)
			           .ThenBy(m => m.MissingCount)
			           .ThenBy(m => m.Recipe.Name),
		};

	public enum MatchMode
	{
		Any,
		All
	}

	public enum SortMode
	{
		MostMatches,
		FewestMissing,
		Name
	}

	public sealed class Preferences
	{
		public List<string> Ingredients { get; set; } = [];
		public MatchMode Mode { get; set; } = MatchMode.Any;
		public SortMode Sort { get; set; } = SortMode.MostMatches;
		public bool Highlight { get; set; } = true;
	}

	private sealed record RecipeMatch(RecipeDto Recipe, int MatchedCount, HashSet<string> MatchedNames, int MissingCount)
	{
		public bool IsFullMatch => MatchedCount > 0 && MissingCount == 0;
	}

}

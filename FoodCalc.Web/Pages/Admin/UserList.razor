@using FoodCalc.Web.Services.Admin
@inject AdminService AdminService
@inject MessageService MessageService

<div class="fh-stack">
	<div class="user-search">
		<SearchBox Placeholder="Search users..." Value="@searchTerm" ValueChanged="OnSearchChanged"/>
	</div>

	@if (pagedResult == null)
	{
		<LoadingSpinner Label="Loading users..."/>
	}
	else if (pagedResult.Items.Any())
	{
		<ul class="user-list">
			@foreach (var user in pagedResult.Items)
			{
				<li>
					<a class="user-list__link" href="/admin/userroles/@user.Email">
						<i class="bi bi-person-circle" aria-hidden="true"></i>
						<span class="user-list__email fh-truncate">@user.Email</span>
						@if (user.Enabled)
						{
							<Badge Variant="Badge.BadgeVariant.Success" Icon="check-circle">Enabled</Badge>
						}
						else
						{
							<Badge Variant="Badge.BadgeVariant.Danger" Icon="slash-circle">Disabled</Badge>
						}
					</a>
					@if (user.Enabled)
					{
						<AppButton Variant="ButtonVariant.OutlineDanger" Size="ButtonSize.Small"
						           OnClick='async () => await ToggleUserAsync(user.Email, false)'>Disable
						</AppButton>
					}
					else
					{
						<AppButton Variant="ButtonVariant.OutlineSuccess" Size="ButtonSize.Small"
						           OnClick='async () => await ToggleUserAsync(user.Email, true)'>Enable
						</AppButton>
					}
				</li>
			}
		</ul>

		<Paginator TotalCount="pagedResult.TotalCount"
		           Page="pagedResult.Page"
		           PageSize="pagedResult.PageSize"
		           PageChanged="OnPageChanged"
		           PageSizeChanged="OnPageSizeChanged"/>
	}
	else
	{
		<EmptyState Icon="people" Title="No users found."/>
	}
</div>

@code {
	private PagedResultDto<UserDto>? pagedResult;
	private int currentPage = 1;
	private int pageSize = 50;
	private string searchTerm = string.Empty;

	protected override async Task OnInitializedAsync() { await LoadUsersAsync(); }

	private async Task LoadUsersAsync()
	{
		pagedResult = await AdminService.GetPagedUsersAsync(currentPage, pageSize, searchTerm)
		                                .OrDefault(new PagedResultDto<UserDto>());
	}

	private async Task OnPageChanged(int page)
	{
		currentPage = page;
		await LoadUsersAsync();
	}

	private async Task OnPageSizeChanged(int size)
	{
		pageSize = size;
		currentPage = 1;
		await LoadUsersAsync();
	}

	private async Task OnSearchChanged(string value)
	{
		searchTerm = value;
		currentPage = 1;
		await LoadUsersAsync();
	}

	public async Task ToggleUserAsync(string email, bool enabled)
	{
		await AdminService.ToggleUserAsync(email, enabled)
		                  .OnSuccess(() =>
		                  {
			                  var user = pagedResult?.Items.FirstOrDefault(u => u.Email == email);
			                  if (user != null)
				                  user.Enabled = enabled;
		                  })
		                  .OnFailure();
	}

}

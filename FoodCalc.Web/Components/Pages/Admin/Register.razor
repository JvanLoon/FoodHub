@page "/register"
@using Microsoft.AspNetCore.Components.Forms
@inject LoginService LoginService
@inject NavigationManager Navigation

<h3>Register</h3>
<EditForm  OnValidSubmit="HandleRegister">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <InputText @bind-Value="Email" placeholder="Email" />
    <InputText @bind-Value="Password" type="password" placeholder="Password" />
    <button type="submit">Register</button>
</EditForm>

@code {
    private string Email { get; set; } = string.Empty;
    private string Password { get; set; } = string.Empty;

    private async Task HandleRegister()
    {
        var response = await LoginService.RegisterAsync(new RegisterDto { Email = Email, Password = Password });

        if (response)
        {
            Navigation.NavigateTo("/login");
        }
        else
        {
            // Show error
        }
    }
}

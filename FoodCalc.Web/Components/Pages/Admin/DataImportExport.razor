@using FoodCalc.Web.Components.Services.Admin
@page "/admin/dataimportexport"
@inject ImportExportService importExportService
@inject MessageService messageService
@inject IJSRuntime JS

<h3>Data Import/Export</h3>

<FoodCalc.Web.Components.Shared.MessageBox />

<div>
    <label>Export</label>
    <button @onclick="ExportData">Export</button>
</div>

<div>
    <label>Import File (.json):</label>
    <input type="file" id="importFileInput" accept=".json" />
    <button @onclick="ImportData">Import</button>
</div>


@code {
    private const string ExportFormat = "json";

    private async Task ExportData()
    {
        try
        {
            await messageService.ShowMessageAsync("Preparing export...", false, 0);
            await importExportService.ExportAsync(ExportFormat);
        }
        catch (Exception ex)
        {
            await messageService.ShowMessageAsync($"Export failed: {ex.Message}", true);
        }
    }

    private async Task ImportData()
    {
        try
        {
            var fileName = await JS.InvokeAsync<string?>("getFileName", "importFileInput");
            if (string.IsNullOrEmpty(fileName))
            {
                await messageService.ShowMessageAsync("Please select a file first.", true);
                return;
            }

            if (!fileName.EndsWith(".json", StringComparison.OrdinalIgnoreCase))
            {
                await messageService.ShowMessageAsync("Only .json files are accepted.", true);
                return;
            }

            var bytes = await JS.InvokeAsync<byte[]>("getFileBytes", "importFileInput");
            if (bytes == null || bytes.Length == 0)
            {
                await messageService.ShowMessageAsync("Could not read the selected file.", true);
                return;
            }

            await importExportService.ImportAsync(bytes, fileName);
        }
        catch (Exception ex)
        {
            await messageService.ShowMessageAsync($"Import failed: {ex.Message}", true);
        }
    }
}

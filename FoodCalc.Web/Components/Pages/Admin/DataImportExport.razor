@using FoodCalc.Web.Components.Services.Admin
@page "/admin/dataimportexport"
@inject ImportExportService importExportService
@inject MessageService messageService
@inject IOptions<ImportExportSettings> ImportExportOptions

<PageTitle>Data Import/Export</PageTitle>

<div class="fh-stack">
    <PageHeader Title="Data Import/Export" />

    <div class="row g-4">
        <div class="col-md-6">
            <AppCard>
                <Header>Export</Header>
                <Body>
                    <p class="fh-muted">Download all data as a .json file.</p>
                    <AppButton Icon="download" OnClick="ExportData">Export</AppButton>
                </Body>
            </AppCard>
        </div>

        <div class="col-md-6">
            <AppCard>
                <Header>Import</Header>
                <Body>
                    <div class="fh-field">
                        <label class="form-label" for="importFile">Import file (.json)</label>
                        <InputFile id="importFile" class="form-control" OnChange="HandleFileSelected" accept=".json" />
                    </div>
                    <AppButton Icon="upload" OnClick="ImportData">Import</AppButton>
                </Body>
            </AppCard>
        </div>
    </div>
</div>

@code {
    private const string ExportFormat = "json";
    private IBrowserFile? _selectedFile;

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
    }

    private async Task ExportData()
    {
        try
        {
            messageService.ShowMessage(WebConstants.Messages.ImportExport.PreparingExport, false, 0);
            await importExportService.ExportAsync(ExportFormat);
        }
        catch (Exception ex)
        {
            messageService.ShowMessage($"Export failed: {ex.Message}", true);
        }
    }

    private async Task ImportData()
    {
        try
        {
            if (_selectedFile == null)
            {
                messageService.ShowMessage(WebConstants.Messages.ImportExport.SelectFileFirst, true);
                return;
            }

            if (!_selectedFile.Name.EndsWith(".json", StringComparison.OrdinalIgnoreCase))
            {
                messageService.ShowMessage(WebConstants.Messages.ImportExport.OnlyJsonAccepted, true);
                return;
            }

            using var stream = _selectedFile.OpenReadStream(maxAllowedSize: ImportExportSettings.DefaultMaxFileSizeInBytes);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();

            if (bytes.Length == 0)
            {
                messageService.ShowMessage(WebConstants.Messages.ImportExport.CouldNotReadFile, true);
                return;
            }

            await importExportService.ImportAsync(bytes, _selectedFile.Name);
        }
        catch (Exception ex)
        {
            messageService.ShowMessage($"Import failed: {ex.Message}", true);
        }
    }
}

@using FoodHub.DTOs;
@using FoodHub.ServiceDefaults;

<div class="add-item-bar no-print">
    <div class="input-group">
        <input type="text"
               class="form-control"
               placeholder="Add custom item..."
               @bind="_newItem"
               @bind:event="oninput"
               @onkeydown="OnInputKeyDown" />
        <AppButton Variant="ButtonVariant.OutlinePrimary" Icon="plus-lg"
                   Disabled="@string.IsNullOrWhiteSpace(_newItem)" OnClick="AddItem">Add</AppButton>
    </div>
</div>

@if (_displayItems.Any())
{
    <ul class="ingredient-print-list">
        @foreach (var (item, index) in _displayItems.Select((item, i) => (item, i)))
        {
            <li>
                <span class="ingredient-text">@item</span>
                <IconButton Icon="x-lg" Title="Remove item" Size="ButtonSize.Small"
                            Variant="ButtonVariant.Danger" CssClass="no-print"
                            OnClick="() => RemoveItem(index)" />
            </li>
        }
    </ul>
}
else
{
    <div class="no-print">
        <EmptyState Icon="cart" Title="No ingredients to display."
                    Message="Select recipes on the Home page or add custom items above." />
    </div>
}

@code {
    [Parameter] public List<RecipeIngredientDto> Ingredients { get; set; } = new();
    [Parameter] public List<string> InitialItems { get; set; } = new();
    [Parameter] public EventCallback<List<string>> OnItemsChanged { get; set; }

    private List<string> _displayItems = new();
    private string _newItem = string.Empty;
    private bool _initialized = false;

    protected override async Task OnParametersSetAsync()
    {
        if (_initialized) return;

        if (Ingredients.Count > 0)
        {
            _initialized = true;
            _displayItems = Ingredients
                .Where(i => !string.IsNullOrWhiteSpace(i.Name))
                .Select(i => $"{i.Name}: {i.Amount.ToFormattedString()} {i.IngredientAmount}")
                .ToList();
            await OnItemsChanged.InvokeAsync(_displayItems);
        }
        else if (InitialItems.Count > 0)
        {
            _initialized = true;
            _displayItems = new List<string>(InitialItems);
        }
    }

    private async Task AddItem()
    {
        if (!string.IsNullOrWhiteSpace(_newItem))
        {
            _displayItems.Add(_newItem.Trim());
            _newItem = string.Empty;
            await OnItemsChanged.InvokeAsync(_displayItems);
        }
    }

    private async Task RemoveItem(int index)
    {
        _displayItems.RemoveAt(index);
        await OnItemsChanged.InvokeAsync(_displayItems);
    }

    private async Task OnInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddItem();
    }
}

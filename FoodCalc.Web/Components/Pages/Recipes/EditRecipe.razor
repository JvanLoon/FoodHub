@page "/recipes/edit/{RecipeId:guid}"
@using FoodCalc.Web.Components.Services
@using FoodHub.DTOs
@inject MessageService MessageService
@inject RecipeService RecipeService
@inject IngredientService IngredientService
@inject ILogger<EditRecipe> Logger

<PageTitle>Edit Recipe</PageTitle>

<!-- Top: Recipe Name -->
<div class="mb-4">
    @if (!isEditingName)
    {
        <h1 class="d-inline">@recipe?.Name</h1>
        <button class="btn btn-sm btn-secondary ms-2" @onclick="() => isEditingName = true">Edit</button>
    }
    else
    {
        <EditForm Model="recipe" OnValidSubmit="SaveRecipeName" class="d-inline">
            <InputText @bind-Value="recipe.Name" class="form-control d-inline w-75" />
            <button class="btn btn-sm btn-primary ms-2" type="submit">Save</button>
            <button class="btn btn-sm btn-outline-secondary ms-2" type="button" @onclick="CancelEditName">Cancel</button>
        </EditForm>
    }
</div>

<div class="row">
    <!-- Left Side: Edit Form -->
    <div class="col-md-6">
        <label for="ingredientSearch" class="form-label">Search Ingredient</label>
        <div class="input-group mb-2">
            <input id="ingredientSearch"
                   class="form-control"
                   type="text"
                   placeholder="Type to search..."
                   @bind="ingredientSearch"
                   @bind:event="oninput"
                   @onfocus="() => dropdownOpen = true"
                   @onblur="OnDropdownBlur"
                   autocomplete="off"
                   @onkeydown="HandleIngredientSearchKeydown"
                   @onkeydown:preventDefault="@(ingredientSearchFocused)" />
            <button class="btn btn-outline-success"
                    type="button"
                    title="Add new ingredient"
                    @onclick="AddIngredient">
                +
            </button>
        </div>

        <EditForm Model="recipeIngredient" OnValidSubmit="AddOrUpdateIngredient">
            <div class="mb-3">
                <div class="dropdown" style="width:100%; position:relative;">
                    <div class="dropdown-menu show"
                         style="width:100%; max-height:200px; overflow-y:auto; display:@(dropdownOpen && FilteredIngredients.Any() ? "block" : "none"); position:absolute; z-index:1000;">
                        @foreach (var ingredient in FilteredIngredients)
                        {
                            <button type="button"
                                    class="dropdown-item @(recipeIngredient.IngredientId == ingredient.Id ? "active" : "")"
                                    @onclick="() => SelectIngredient(ingredient)">
                                @ingredient.Name
                            </button>
                        }
                        @if (!FilteredIngredients.Any())
                        {
                            <div class="dropdown-item text-muted">No ingredients found. Click + to add.</div>
                        }
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label for="amountInput" class="form-label">Amount</label>
                <InputNumber id="amountInput" @bind-Value="recipeIngredient.Amount" class="form-control" />
            </div>

            <div class="mb-3">
                <label for="amountTypeSelect" class="form-label">Amount Type</label>
                <InputSelect id="amountTypeSelect" @bind-Value="recipeIngredient.IngredientAmount" class="form-select">
                    @foreach (IngredientAmountTypeDto amountType in Enum.GetValues<IngredientAmountTypeDto>())
                    {
                        <option value="@amountType">@amountType</option>
                    }
                </InputSelect>
            </div>

            <button class="btn btn-primary me-2" type="submit">Add/Save</button>
            <button class="btn btn-outline-primary me-2" type="button" @onclick="ClearForm">Clear</button>
        </EditForm>
    </div>

    <!-- Right Side: Recipe Name and Ingredients -->
    <div class="col-md-6">
        <ul class="list-group">
            @foreach (var ingredient in recipe?.RecipeIngredient ?? new List<RecipeIngredientDto>())
            {
                <li class="list-group-item d-flex">
                    <span>
                        @ingredient.Ingredient!.Name - @ingredient.Amount.ToFormattedString() @ingredient.IngredientAmount
                    </span>
                    <span class="ms-auto">
                        <button class="btn btn-sm btn-secondary me-2" @onclick="() => EditIngredient(ingredient)">Edit</button>
                        <button class="btn btn-sm btn-danger" type="button" @onclick="() => DeleteIngredient(ingredient.Id)">Delete</button>
                    </span>
                </li>
            }
        </ul>
    </div>
</div>

<FoodCalc.Web.Components.Shared.MessageBox />

@code {
    [Parameter] public Guid RecipeId { get; set; }

    private RecipeDto recipe;
    private List<IngredientDto> ingredients = new();
    private RecipeIngredientDto recipeIngredient = new();
    private Guid noIngredient;
    private bool isEditingName = false;
    private string ingredientSearch = string.Empty;
    private IEnumerable<IngredientDto> FilteredIngredients =>
        string.IsNullOrWhiteSpace(ingredientSearch)
            ? ingredients
            : ingredients.Where(i => i.Name.Contains(ingredientSearch, StringComparison.OrdinalIgnoreCase));
    private bool dropdownOpen = false;
    private bool ingredientSearchFocused = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            recipe = await RecipeService.GetRecipeByIdAsync(RecipeId) ?? new RecipeDto();
            ingredients = await IngredientService.GetAllIngredientsAsync();
            noIngredient = Guid.NewGuid();
            ClearForm();
        }
        catch (Exception ex)
        {
            await MessageService.ShowMessageAsync(ex.Message, true, 20000);
        }
    }

    private async Task AddOrUpdateIngredient()
    {
        try
        {
            recipeIngredient.RecipeId = RecipeId;
            await RecipeService.AddIngredient(recipeIngredient);
            await MessageService.ShowMessageAsync("Ingredient added/updated successfully", false);

            // Clear form
            ClearForm();
            recipe = await RecipeService.GetRecipeByIdAsync(RecipeId); // Refresh the list
        }
        catch (Exception ex)
        {
            await MessageService.ShowMessageAsync("Failed to add/update ingredient", true);
        }
    }

    private void EditIngredient(RecipeIngredientDto ingredient)
    {
        recipeIngredient = new RecipeIngredientDto
        {
            Id = ingredient.Id,
            // RecipeId = ingredient.RecipeId,
            IngredientId = ingredient.IngredientId,
            Amount = ingredient.Amount,
            IngredientAmount = ingredient.IngredientAmount
        };
        ingredientSearch = ingredient.Ingredient.Name;
    }

    private async Task DeleteIngredient(Guid recipeIngredientId)
    {
        try
        {
            await RecipeService.DeleteIngredient(recipeIngredientId);
            await MessageService.ShowMessageAsync("Ingredient deleted successfully", false);
            ClearForm();
            recipe = await RecipeService.GetRecipeByIdAsync(RecipeId); // Refresh the list
        }
        catch (Exception ex)
        {
            await MessageService.ShowMessageAsync("Failed to delete ingredient", true);
        }
    }

    private void ClearForm()
    {
        ingredientSearch = string.Empty;
        recipeIngredient = new RecipeIngredientDto { Id = Guid.NewGuid(), RecipeId = RecipeId, IngredientId = noIngredient };
    }

    private async Task SaveRecipeName()
    {
        try
        {
            await RecipeService.UpdateRecipeName(RecipeId, recipe.Name!);
            isEditingName = false;
            recipe = await RecipeService.GetRecipeByIdAsync(RecipeId); // Refresh
            await MessageService.ShowMessageAsync("Recipe name updated", false);
        }
        catch (Exception ex)
        {
            await MessageService.ShowMessageAsync("Failed to update recipe name", true);
        }
    }

    private async Task AddIngredient()
    {
        try
        {
            var ingredient = new CreateIngredientDto { Name = ingredientSearch };

            await IngredientService.AddIngredientAsync(ingredient);

            ingredients = await IngredientService.GetAllIngredientsAsync();

            recipeIngredient.IngredientId = ingredients.FirstOrDefault(i => i.Name == ingredientSearch)?.Id ?? Guid.Empty;
            if (recipeIngredient.IngredientId == Guid.Empty)
            {
                //only clear when failed
                ingredientSearch = string.Empty;
            }

            await MessageService.ShowMessageAsync("Ingredient added", false);
        }
        catch (Exception ex)
        {
            await MessageService.ShowMessageAsync("Failed to add ingredient", true);
        }
    }

    private void SelectIngredient(IngredientDto ingredient)
    {
        recipeIngredient.IngredientId = ingredient.Id;
        ingredientSearch = ingredient.Name;
        dropdownOpen = false;
    }

    private async Task OnDropdownBlur()
    {
        // Delay to allow click event to register before closing dropdown
        await Task.Delay(150);
        dropdownOpen = false;
    }

    private void CancelEditName()
    {
        isEditingName = false;
    }

    private async Task HandleIngredientSearchKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await AddIngredient();
        }
    }
}

@page "/recipes/edit/{RecipeId:guid}"
@using FoodCalc.Web.Components.Services
@using FoodHub.Persistence.Entities
@inject RecipeService RecipeService
@inject IngredientService IngredientService
@inject ILogger<EditRecipe> Logger

<PageTitle>Edit Recipe</PageTitle>

<!-- Top: Recipe Name -->
<div class="mb-4">
    @if (!isEditingName)
    {
        <h1 class="d-inline">@recipe?.Name</h1>
        <button class="btn btn-sm btn-secondary ms-2" @onclick="() => isEditingName = true">Edit</button>
    }
    else
    {
        <EditForm Model="recipe" OnValidSubmit="SaveRecipeName" class="d-inline">
            <InputText @bind-Value="recipe.Name" class="form-control d-inline w-75" />
            <button class="btn btn-sm btn-primary ms-2" type="submit">Save</button>
            <button class="btn btn-sm btn-outline-secondary ms-2" type="button" @onclick="CancelEditName">Cancel</button>
        </EditForm>
    }
</div>

<div class="row">
    <!-- Right Side: Edit Form -->
    <div class="col-md-6">
        <EditForm Model="recipeIngredient" OnValidSubmit="AddOrUpdateIngredient">
            @*<div class="mb-3">
                <label for="ingredientSelect" class="form-label">Select Ingredient</label>
                <InputSelect id="ingredientSelect" @bind-Value="recipeIngredient.IngredientId" class="form-select">
                    <option value="@noIngredient">Select an Ingredient</option>
                    @foreach (var ingredient in ingredients)
                    {
                        <option value="@ingredient.Id">@ingredient.Name</option>
                    }
                </InputSelect>
            </div> *@

            <div class="mb-3">
                <label for="ingredientSearch" class="form-label">Search Ingredient</label>
                <div class="input-group mb-2">
                    <input id="ingredientSearch"
                           class="form-control"
                           type="text"
                           placeholder="Type to search..."
                           @bind="ingredientSearch"
                           @bind:event="oninput" />
                    <button class="btn btn-outline-success"
                            type="button"
                            title="Add new ingredient"
                            @onclick="AddIngredient">
                        +
                    </button>
                </div>

                <label for="ingredientSelect" class="form-label mt-2">Select Ingredient</label>
                <select id="ingredientSelect"
                        class="form-select"
                        @bind="recipeIngredient.IngredientId">
                    <option value="@noIngredient">Select an Ingredient</option>
                    @foreach (var ingredient in FilteredIngredients)
                    {
                        <option value="@ingredient.Id">@ingredient.Name</option>
                    }
                </select>
                @if (!FilteredIngredients.Any())
                {
                    <div class="text-muted small mt-1">No ingredients found. Click + to add.</div>
                }
            </div>

            <div class="mb-3">
                <label for="amountInput" class="form-label">Amount</label>
                <InputNumber id="amountInput" @bind-Value="recipeIngredient.Amount" class="form-control" />
            </div>

            <div class="mb-3">
                <label for="amountTypeSelect" class="form-label">Amount Type</label>
                <InputSelect id="amountTypeSelect" @bind-Value="recipeIngredient.IngredientAmount" class="form-select">
                    @foreach (IngredientAmountType amountType in Enum.GetValues<IngredientAmountType>())
                    {
                        <option value="@amountType">@amountType</option>
                    }
                </InputSelect>
            </div>

            <button class="btn btn-primary me-2" type="submit">Add/Save</button>
            <button class="btn btn-outline-primary me-2" type="button" @onclick="ClearForm">Clear</button>
            @if (IsEditMode)
            {
                <button class="btn btn-sm btn-danger" type="button" @onclick="() => DeleteIngredient(recipeIngredient.Id)">Delete</button>
            }
        </EditForm>
    </div>

    <!-- Left Side: Recipe Name and Ingredients -->
    <div class="col-md-6">
        <ul class="list-group">
            @foreach (var ingredient in recipe?.RecipeIngredient ?? new List<RecipeIngredient>())
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    @ingredient.Ingredient.Name - @ingredient.Amount @ingredient.IngredientAmount
                    <button class="btn btn-sm btn-secondary ms-2" @onclick="() => EditIngredient(ingredient)">Edit</button>
                </li>
            }
        </ul>
    </div>
</div>

@if (showMessage)
{
    <div class="alert @(IsError ? "alert-danger" : "alert-success")">
        @_message
    </div>
}

@code {
    [Parameter] public Guid RecipeId { get; set; }

    private Recipe recipe;
    private List<Ingredient> ingredients = new();
    private RecipeIngredient recipeIngredient = new();
    private bool IsEditMode => recipeIngredient != null && recipeIngredient.IngredientId != noIngredient;
    private Guid noIngredient;
    private bool isEditingName = false;
    private string ingredientSearch = string.Empty;
    private IEnumerable<Ingredient> FilteredIngredients =>
        string.IsNullOrWhiteSpace(ingredientSearch)
            ? ingredients
            : ingredients.Where(i => i.Name.Contains(ingredientSearch, StringComparison.OrdinalIgnoreCase));

    private bool showMessage = false;
    private bool IsError = false;
    private string _message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            recipe = await RecipeService.GetRecipeByIdAsync(RecipeId) ?? new Recipe();
            ingredients = await IngredientService.GetAllIngredientsAsync();
            noIngredient = Guid.NewGuid();
            recipeIngredient.IngredientId = noIngredient;
            ClearForm();
        }
        catch (Exception ex)
        {
            ShowMessage("Failed to load data", true);
            Logger.LogError($"Error loading data: {ex.Message}");
        }
    }

    private async Task AddOrUpdateIngredient()
    {
        try
        {
            recipeIngredient.RecipeId = RecipeId;
            await RecipeService.AddIngredient(recipeIngredient);
            ShowMessage("Ingredient added/updated successfully", false);

            // Clear form
            recipeIngredient = new RecipeIngredient { RecipeId = RecipeId, IngredientId = Guid.Empty };
            recipe = await RecipeService.GetRecipeByIdAsync(RecipeId); // Refresh the list
        }
        catch (Exception ex)
        {
            ShowMessage("Failed to add/update ingredient", true);
            Logger.LogError($"Error: {ex.Message}");
        }
    }

    private void EditIngredient(RecipeIngredient ingredient)
    {
        recipeIngredient = new RecipeIngredient
        {
            Id = ingredient.Id,
            // RecipeId = ingredient.RecipeId,
            IngredientId = ingredient.IngredientId,
            Amount = ingredient.Amount,
            IngredientAmount = ingredient.IngredientAmount
        };
    }

    private async Task DeleteIngredient(Guid recipeIngredientId)
    {
        try
        {
            await RecipeService.DeleteIngredient(recipeIngredientId);
            ShowMessage("Ingredient deleted successfully", false);
            ClearForm();
            recipe = await RecipeService.GetRecipeByIdAsync(RecipeId); // Refresh the list
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowMessage("Failed to delete ingredient", true);
            Logger.LogError($"Error deleting ingredient: {ex.Message}");
        }
    }

    private void ClearForm()
    {
        ingredientSearch = string.Empty;
        recipeIngredient = new RecipeIngredient { Id = Guid.NewGuid(), RecipeId = RecipeId, IngredientId = noIngredient };
    }

    private async Task SaveRecipeName()
    {
        try
        {
            await RecipeService.UpdateRecipeName(RecipeId, recipe.Name!);
            isEditingName = false;
            recipe = await RecipeService.GetRecipeByIdAsync(RecipeId); // Refresh
            ShowMessage("Recipe name updated", false);
        }
        catch (Exception ex)
        {
            ShowMessage("Failed to update recipe name", true);
            Logger.LogError($"Error updating recipe name: {ex.Message}");
        }
    }

    private async Task AddIngredient()
    {
        try
        {
            var ingredient = new Ingredient { Id = Guid.NewGuid(), Name = ingredientSearch };
            await IngredientService.AddIngredientAsync(ingredient);
            ingredients = await IngredientService.GetAllIngredientsAsync();
            ingredientSearch = string.Empty;
            ShowMessage("Ingredient added", false);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowMessage("Failed to add ingredient", true);
            Logger.LogError($"Error adding ingredient: {ex.Message}");
        }
    }

    private void CancelEditName()
    {
        isEditingName = false;
    }

    async Task ShowMessage(string message, bool isError, int timeInMs = 2000)
    {
        _message = message;
        IsError = isError;

        showMessage = true;
        StateHasChanged();

        await Task.Delay(timeInMs);

        showMessage = false;
        _message = string.Empty;
        IsError = false;
        StateHasChanged();
    }
}

@page "/ingredients"

@using FoodCalc.Web.Components.Services
@using FoodHub.DTOs
@inject IngredientService IngredientService
@inject MessageService MessageService


<div class="ingredient-layout">
    <div class="ingredient-header">
        <h3>Ingredients</h3>
        <div class="mb-3">
            <input type="text" class="form-control" placeholder="Search ingredients..." value="@searchTerm" @oninput="OnSearchInput" />
        </div>
    </div>

    <div class="ingredient-body">
        @if (pagedResult == null)
        {
            <p>Loading...</p>
        }
        else
        {
            <table class="table table-hover ingredient-table">
                <thead>
                    <tr>
                        <th class="w-100">Name</th>
                        <th class="text-end" style="white-space: nowrap;">Shopping Cart</th>
                        <th class="text-end" style="white-space: nowrap;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (pagedResult.Items.Any())
                    {
                        var index = 0;
                        @foreach (IngredientDto ingredient in pagedResult.Items)
                        {
                            var rowClass = index % 2 == 0 ? "table-row-even" : "table-row-odd";
                            <tr class="@rowClass">
                                <td class="w-100 text-wrap">
                                    @if (editingIngredientId == ingredient.Id)
                                    {
                                        <input type="text" class="form-control form-control-sm" @bind="editingName" @onkeydown="(e) => OnEditInputKeyDown(e, ingredient)" />
                                    }
                                    else
                                    {
                                        @ingredient.Name
                                    }
                                </td>
                                <td class="text-center" style="white-space: nowrap;">
                                    <input type="checkbox"
                                    checked="@ingredient.ShouldBeAddedToShoppingCart"
                                    @onchange="(e) => OnCheckboxChanged(ingredient, e)" />
                                </td>
                                <td class="text-end" style="white-space: nowrap;">
                                    @if (editingIngredientId == ingredient.Id)
                                    {
                                        <button class="btn btn-success btn-sm ingredient-action-btn" @onclick="() => SaveEdit(ingredient)">Save</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-primary btn-sm ingredient-action-btn" @onclick="() => StartEdit(ingredient)">Edit</button>
                                    }
                                    <button class="btn btn-danger btn-sm ms-3" @onclick="() => DeleteIngredient(ingredient.Id)">Delete</button>
                                </td>
                            </tr>
                            index++;
                        }
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="ingredient-footer">
        @if (pagedResult != null)
        {
            <FoodCalc.Web.Components.Shared.Paginator
                TotalCount="pagedResult.TotalCount"
                Page="pagedResult.Page"
                PageSize="pagedResult.PageSize"
                PageChanged="OnPageChanged"
                PageSizeChanged="OnPageSizeChanged" />
        }
    </div>
</div>

<FoodCalc.Web.Components.Shared.MessageBox />

@code {
    private PagedResultDto<IngredientDto>? pagedResult;
    private int currentPage = 1;
    private int pageSize = 10;
    private Guid? editingIngredientId = null;
    private string editingName = string.Empty;
    private string searchTerm = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadIngredientsAsync();
    }

    private async Task LoadIngredientsAsync()
    {
        try
        {
            pagedResult = await IngredientService.GetPagedIngredientsAsync(currentPage, pageSize, searchTerm);
        }
        catch (Exception ex)
        {
            pagedResult = new();
            await MessageService.ShowMessageAsync(ex.Message, true, 20000);
        }
    }

    private async Task OnPageChanged(int page)
    {
        currentPage = page;
        await LoadIngredientsAsync();
    }

    private async Task OnPageSizeChanged(int size)
    {
        pageSize = size;
        currentPage = 1;
        await LoadIngredientsAsync();
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;
        currentPage = 1;
        await LoadIngredientsAsync();
    }

    private async Task OnCheckboxChanged(IngredientDto ingredient, ChangeEventArgs e)
    {
        ingredient.ShouldBeAddedToShoppingCart = (bool)e.Value!;

        var updateDto = new UpdateIngredientDto 
        { 
            Id = ingredient.Id, 
            Name = ingredient.Name, 
            ShouldBeAddedToShoppingCart = ingredient.ShouldBeAddedToShoppingCart 
        };
        await IngredientService.UpdateIngredient(updateDto);

        await MessageService.ShowMessageAsync("Ingredient updated successfully!", false);
    }

    private void StartEdit(IngredientDto ingredient)
    {
        editingIngredientId = ingredient.Id;
        editingName = ingredient.Name;
    }

    private async Task SaveEdit(IngredientDto ingredient)
    {
        if (!string.IsNullOrWhiteSpace(editingName) && editingName != ingredient.Name)
        {
            ingredient.Name = editingName;
            var updateDto = new UpdateIngredientDto
            {
                Id = ingredient.Id,
                Name = ingredient.Name,
                ShouldBeAddedToShoppingCart = ingredient.ShouldBeAddedToShoppingCart
            };
            await IngredientService.UpdateIngredient(updateDto);
            await MessageService.ShowMessageAsync("Ingredient name updated successfully!", false);
        }
        editingIngredientId = null;
        editingName = string.Empty;
    }

    private async Task OnEditInputKeyDown(KeyboardEventArgs e, IngredientDto ingredient)
    {
        if (e.Key == "Enter")
        {
            await SaveEdit(ingredient);
        }
    }

    private async Task DeleteIngredient(Guid id)
    {
        var success = await IngredientService.DeleteIngredient(id);
        if (success)
        {
            await LoadIngredientsAsync();
            await MessageService.ShowMessageAsync("Ingredient deleted successfully!", false);
        }
        else
        {
            await MessageService.ShowMessageAsync("Failed to delete ingredient.", true);
        }
    }
}

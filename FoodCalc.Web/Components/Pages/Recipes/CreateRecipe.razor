@page "/recipes/create"
@using FoodCalc.Web.Components.Services
@using FoodHub.DTOs
@inject RecipeService RecipeService
@inject MessageService MessageService
@inject NavigationManager NavigationManager

<PageTitle>Create Recipe</PageTitle>

<div class="fh-stack">
    <PageHeader Title="Create a New Recipe" />

    <div class="create-card">
        <AppCard>
            <EditForm Model="recipe" OnValidSubmit="CreateRecipeAsync" FormName="create-recipe-form">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <TextField Label="Recipe Name" Placeholder="e.g. Spaghetti Bolognese" @bind-Value="recipe.Name" />

                <AppButton Type="submit" Icon="plus-lg">Create</AppButton>
            </EditForm>
        </AppCard>
    </div>
</div>

@code {
    private CreateRecipeDto recipe = new();

    private async Task CreateRecipeAsync()
    {
        var result = await RecipeService.AddRecipe(recipe);

        if (result.Success && result.Data?.Id is Guid id && id != Guid.Empty)
        {
            // Navigate to EditRecipe page with the new recipe's ID
            NavigationManager.NavigateTo($"/recipes/edit/{id}");
        }
        else
        {
            await MessageService.ShowMessageAsync(result.Error ?? "Failed to create recipe.", true);
        }
    }
}

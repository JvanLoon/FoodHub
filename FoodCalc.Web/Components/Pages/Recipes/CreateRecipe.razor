@page "/recipes/create"
@using FoodCalc.Web.Components.Services
@using FoodHub.DTOs
@inject RecipeService RecipeService
@inject MessageService MessageService
@inject NavigationManager NavigationManager

<PageTitle>Create Recipe</PageTitle>

<h2>Create a New Recipe</h2>

<EditForm Model="recipe" OnValidSubmit="CreateRecipeAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="recipeName" class="form-label">Recipe Name</label>
        <InputText id="recipeName" class="form-control" @bind-Value="recipe.Name" required />
    </div>

    <button class="btn btn-primary" type="submit">Create</button>
</EditForm>

<FoodCalc.Web.Components.Shared.MessageBox />

@code {
    private CreateRecipeDto recipe = new();

    private async Task CreateRecipeAsync()
    {
        try
        {
            // Create the recipe (assumes RecipeService.AddRecipeAsync returns the created Recipe with Id)
            var createdRecipe = await RecipeService.AddRecipe(recipe);

            if (createdRecipe?.Id != Guid.Empty)
            {
                // Navigate to EditRecipe page with the new recipe's ID
                NavigationManager.NavigateTo($"/recipes/edit/{createdRecipe!.Id}");
            }
            else
            {
                await MessageService.ShowMessageAsync("Failed to create recipe.", true);
            }
        }
        catch (Exception ex)
        {
            await MessageService.ShowMessageAsync("Error creating recipe.", true);
        }
    }
}

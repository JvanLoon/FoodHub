@page "/recipes/make"
@using FoodCalc.Web.Components.Services
@using FoodHub.Persistence.Entities
@using Microsoft.Extensions.Logging

@inject RecipeService recipeService
@inject IngredientService IngredientService
@inject ILogger<CreateRecipe> logger


<PageTitle>Make Recipe</PageTitle>

<EditForm Model="recipeIngredient" OnSubmit="@UpdateRecipe">
    <div class="mb-3">
        <label for="recipeSelect" class="form-label">Select Recipe</label>
        <InputSelect id="recipeSelect" @bind-Value="recipeIngredient.RecipeId" class="form-select">
            <option value="">Select a Recipe</option>
            @foreach (var recipe in recipes)
            {
                <option value="@recipe.Id">@recipe.Name</option>
            }
        </InputSelect>
    </div>

    <div class="mb-3">
        <label for="ingredientSelect" class="form-label">Select Ingredient</label>
        <InputSelect id="ingredientSelect" @bind-Value="recipeIngredient.IngredientId" class="form-select">
            <option value="">Select an Ingredient</option>
            @foreach (var ingredient in ingredients)
            {
                <option value="@ingredient.Id">@ingredient.Name</option>
            }
        </InputSelect>
    </div>

    <div class="mb-3">
        <label for="amountInput" class="form-label">Amount</label>
        <InputNumber id="amountInput" @bind-Value="recipeIngredient.Amount" class="form-control" />
    </div>

    <div class="mb-3">
        <label for="amountTypeSelect" class="form-label">Amount Type</label>
        <InputSelect id="amountTypeSelect" @bind-Value="recipeIngredient.IngredientAmount" class="form-select">
            @foreach (IngredientAmountType amountType in Enum.GetValues<IngredientAmountType>())
            {
                <option value="@amountType">@amountType</option>
            }
        </InputSelect>
    </div>

    <button class="btn btn-primary">Update recipe</button>
</EditForm>


@if (showMessage)
{
    @if (IsError)
    {
        <div class="alert alert-danger fade-out">
            @_message
        </div>
    }
    else
    {
        <div class="alert alert-success fade-out">
            @_message
        </div>
    }
}

@code{
    private bool showMessage = false;
    private bool IsError = false;
    private string _message = string.Empty;

    private List<Recipe> recipes = new();
    private List<Ingredient> ingredients = new();

    private RecipeIngredient recipeIngredient = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            recipes = await recipeService.GetAllRecipesAsync();
            ingredients = await IngredientService.GetAllIngredientsAsync();
        }
        catch (Exception ex)
        {
            await ShowMessage("Failed to load data", true);
            logger.LogError($"An error occurred while loading data: {ex.Message}");
        }
    }

    async Task UpdateRecipe()
    {
        try
        {
            await recipeService.AddIngredient(recipeIngredient);

            recipeIngredient.Id = Guid.NewGuid();
            recipeIngredient.IngredientAmount = IngredientAmountType.None;
            recipeIngredient.IngredientId = Guid.Empty;
            recipeIngredient.Amount = 0;

            //recipeService.navigationManager.NavigateTo("/");
        }
        catch (Exception ex)
        {
            await ShowMessage("Something went wrong", true);
            logger.LogError($"An unexpected error occurred: {ex.Message}");
        }
        finally
        {
            StateHasChanged();
        }
    }

    async Task ShowMessage(string message, bool isError, int timeInMs = 2000)
    {
        _message = message;
        IsError = isError;

        showMessage = true;
        StateHasChanged();

        await Task.Delay(timeInMs);

        showMessage = false;
        _message = string.Empty;
        IsError = false;
        StateHasChanged();
    }
}

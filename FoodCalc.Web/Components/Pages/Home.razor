@using FoodCalc.Web.Components.Services
@using FoodHub.Persistence.Entities

@page "/"

@inject RecipeService recipeService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>Home</PageTitle>

<h1>list of recipes</h1>

<div class="container-fluid ps-3">
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (Recipe recipe in Recipes)
        {
            <div class="col d-flex w-auto">
                <div class="card h-100 shadow-sm">
                    <img src="https://placehold.co/400x200?text=Recipe\nImage" class="card-img-top" alt="Recipe image">
                    <div class="card-body">
                        <h5 class="card-title">@recipe.Name</h5>
                        <p class="card-text mb-1"><strong>Ingredients:</strong></p>
                        <ul class="list-unstyled mb-0">
                            @if (recipe.RecipeIngredient != null)
                            {
                                foreach (RecipeIngredient ingredient in recipe.RecipeIngredient)
                                {
                                    <li class="d-flex justify-content-between align-items-center">
                                        <span>@ingredient.Ingredient.Name</span>
                                        <span>@ingredient.Amount @ingredient.IngredientAmount.ToString()</span>
                                    </li>
                                }
                            }
                        </ul>
                    </div>
                    <div class="card-footer bg-transparent border-0 text-end">
                        <button class="btn btn-primary" @onclick="() => EditRecipe(recipe.Id)">Edit</button>
                        <button class="btn btn-danger" @onclick="() => DeleteRecipe(recipe.Id)">Delete</button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(_errormessage))
{
    <p>@_errormessage</p>
}


@code {
    private string _errormessage = string.Empty;
    List<Recipe> Recipes = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Recipes = await recipeService.GetAllRecipesAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _errormessage = ex.Message;
            StateHasChanged();
            throw ex;
        }
    }

    private void EditRecipe(Guid recipeId)
    {
        NavigationManager.NavigateTo($"/recipes/edit/{recipeId}");
    }

    private async Task DeleteRecipe(Guid recipeId)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this recipe?");
        if (!confirmed)
            return;

        try
        {
            await recipeService.DeleteRecipe(recipeId);
            Recipes = await recipeService.GetAllRecipesAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _errormessage = ex.Message;
            StateHasChanged();
        }
    }
}

@page "/"

@inject IJSRuntime JS
@inject RecipeService recipeService
@inject AggregatedIngredientService AggregatedIngredientService
@inject MessageService MessageService
@inject NavigationManager NavigationManager

<PageTitle>Home</PageTitle>

<h1>list of recipes</h1>

<div class="mb-3">
    <button class="btn btn-success" @onclick="OpenAggregatedIngredientsPage" disabled="@(!SelectedRecipeIds.Any())">
        Get Ingredients from Selected Recipes
    </button>
</div>

<div class="container-fluid ps-3">
    @if (Recipes.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (RecipeDto recipe in Recipes)
            {
                <div class="col d-flex card-equal-width p-1">
                    <div class="card h-100 w-100 shadow-sm @CardCssClass(recipe.Id)" draggable="false" onmousedown="() => ToggleRecipeSelection(recipe.Id, !SelectedRecipeIds.Contains(recipe.Id))">
                        <img src="https://placehold.co/400x200?text=Recipe\nImage" class="card-img-top" alt="Recipe image" draggable="false">
                        <div class="card-body">
                            <h5 class="card-title">@recipe.Name</h5>
                            <p class="card-text mb-1"><strong>Ingredients:</strong></p>
                            <ul class="list-unstyled mb-0">
                                @if (recipe.RecipeIngredient != null)
                                {
                                    foreach (RecipeIngredientDto ingredient in recipe.RecipeIngredient)
                                    {
                                        if (ingredient.Ingredient != null)
                                        {
                                            <li class="d-flex justify-content-between align-items-center">
                                                <span>@ingredient.Ingredient.Name</span>
                                                <span>@ingredient.Amount.ToFormattedString() @ingredient.IngredientAmount.ToString()</span>
                                            </li>
                                        }
                                    }
                                }
                            </ul>
                        </div>
                        <div class="card-footer bg-transparent border-0 text-end">
                            <button class="btn btn-primary" @onclick="() => EditRecipe(recipe.Id)" @onclick:stopPropagation>Edit</button>
                            <button class="btn btn-danger" @onclick="() => DeleteRecipe(recipe.Id)" @onclick:stopPropagation>Delete</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p>No Recipes, something went wrong</p>
    }

</div>

<FoodCalc.Web.Components.Shared.MessageBox />


@code {
    List<RecipeDto> Recipes = new();
    private HashSet<Guid> SelectedRecipeIds = new();
    private List<RecipeIngredientDto> AggregatedIngredients = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Recipes = await recipeService.GetAllRecipesAsync();
        }
        catch (Exception ex)
        {
            Recipes = [];
            await MessageService.ShowMessageAsync(ex.Message, true, 0);
        }
    }

    private async Task OpenAggregatedIngredientsPage()
    {
        AggregateIngredients();
        AggregatedIngredientService.AggregatedIngredients = AggregatedIngredients;

        // Open the new page in a new tab
        await JS.InvokeVoidAsync("window.open", "/aggregated-ingredients", "_blank");
        //clean list when new page is opened
        AggregatedIngredients = new();
    }

    private string CardCssClass(Guid recipeId) =>
        SelectedRecipeIds.Contains(recipeId) ? "border-primary border-3" : string.Empty;

    private void ToggleRecipeSelection(Guid recipeId, bool? isChecked)
    {
        if (isChecked == true)
            SelectedRecipeIds.Add(recipeId);
        else
            SelectedRecipeIds.Remove(recipeId);
    }

    private void AggregateIngredients()
    {
        var ingredientDict = new Dictionary<(Guid IngredientId, IngredientAmountTypeDto AmountType), RecipeIngredientDto>();

        foreach (var recipe in Recipes.Where(r => SelectedRecipeIds.Contains(r.Id)))
        {
            if (recipe.RecipeIngredient == null) continue;

            foreach (var ri in recipe.RecipeIngredient)
            {
                if (ri.Ingredient!.ShouldBeAddedToShoppingCart)
                {
                    var key = (ri.IngredientId, ri.IngredientAmount);
                    if (ingredientDict.TryGetValue(key, out var existing))
                    {
                        existing.Amount += ri.Amount;
                    }
                    else
                    {
                        // Clone to avoid mutating original
                        ingredientDict[key] = new RecipeIngredientDto
                        {
                            Ingredient = ri.Ingredient,
                            IngredientId = ri.IngredientId,
                            IngredientAmount = ri.IngredientAmount,
                            Amount = ri.Amount
                        };
                    }
                }
            }
        }

        AggregatedIngredients = ingredientDict.Values.OrderBy(i => i.Ingredient!.Name).ToList();
    }

    private void EditRecipe(Guid recipeId)
    {
        NavigationManager.NavigateTo($"/recipes/edit/{recipeId}");
    }

    private async Task DeleteRecipe(Guid recipeId)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this recipe?");
        if (!confirmed)
            return;

        try
        {
            await recipeService.DeleteRecipe(recipeId);
            Recipes = await recipeService.GetAllRecipesAsync();
        }
        catch (Exception ex)
        {
            await MessageService.ShowMessageAsync(ex.Message, true);
        }
    }
}

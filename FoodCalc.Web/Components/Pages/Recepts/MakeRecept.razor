@page "/recepts/make"
@using FoodCalc.Web.Services
@using FoodHub.Persistence.Entities
@using Microsoft.Extensions.Logging

@inject ReceptService receptService
@inject ILogger<CreateRecept> logger


<PageTitle>Make Recept</PageTitle>

<EditForm Model="receptIngredient" OnSubmit="@UpdateRecept">
	<div class="mb-3">
		<label for="receptSelect" class="form-label">Select Recept</label>
		<select id="receptSelect" @bind="receptIngredient.ReceptId" class="form-select">
			<option value="">Select a Recept</option>
			@foreach (var recept in recepts)
			{
				<option value="@recept.Id">@recept.Name</option>
			}
		</select>
	</div>

	<div class="mb-3">
		<label for="ingredientSelect" class="form-label">Select Ingredient</label>
		<select id="ingredientSelect" @bind="receptIngredient.IngredientId" class="form-select">
			<option value="">Select an Ingredient</option>
			@foreach (var ingredient in ingredients)
			{
				<option value="@ingredient.Id">@ingredient.Name</option>
			}
		</select>
	</div>

	<div class="mb-3">
		<label for="amountInput" class="form-label">Amount</label>
		<input type="number" id="amountInput" @bind="receptIngredient.Amount" class="form-control" />
	</div>

	<div class="mb-3">
		<label for="amountTypeSelect" class="form-label">Amount Type</label>
		<select id="amountTypeSelect" @bind="receptIngredient.IngredientAmount" class="form-select">
			@foreach (IngredientAmountType amountType in Enum.GetValues<IngredientAmountType>())
			{
				<option value="@amountType">@amountType</option>
			}
		</select>
	</div>

<button class="btn btn-primary">Update Recept</button>
</EditForm>


@if (showMessage)
{
    @if (IsError)
    {
        <div class="alert alert-danger fade-out">
            @_message
        </div>
    }
    else
    {
        <div class="alert alert-success fade-out">
            @_message
        </div>
    }
}

@code{
    private bool showMessage = false;
    private bool IsError = false;
    private string _message = string.Empty;
    private Recept recept = new();
    private ReceptIngredient receptIngredient = new();
    private List<Recept> recepts = new();
    private List<Ingredient> ingredients = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
	        recepts = await receptService.GetReceptsAsync();
            ingredients = await receptService.GetIngredientsAsync();
        }
        catch (Exception ex)
        {
            ShowMessage("Failed to load data", true);
            logger.LogError($"An error occurred while loading data: {ex.Message}");
        }
    }

    async Task UpdateRecept()
    {
        try
        {
            if (receptIngredient.IngredientAmount == IngredientAmountType.None || receptIngredient.IngredientId == Guid.Empty || receptIngredient.ReceptId == Guid.Empty || receptIngredient.Amount == 0)
            {
                ShowMessage("all 4 fields is required", true);
                return;
            }

            recept.ReceptIngredient.Add(receptIngredient);

            await receptService.UpdateRecept(recept);

            receptIngredient.IngredientAmount = IngredientAmountType.None;
            receptIngredient.IngredientId = Guid.Empty;
            receptIngredient.ReceptId = Guid.Empty;
            receptIngredient.Amount = 0;

            //receptService.navigationManager.NavigateTo("/");
        }
        catch (Exception ex)
        {
            ShowMessage("Something went wrong", true);
            logger.LogError($"An unexpected error occurred: {ex.Message}");
        }
        finally
        {
            StateHasChanged();
        }
    }

    async Task ShowMessage(string message, bool isError, int timeInMs = 2000)
    {
        _message = message;
        IsError = isError;

        showMessage = true;
        StateHasChanged();

        await Task.Delay(timeInMs);

        showMessage = false;
        _message = string.Empty;
        IsError = false;
        StateHasChanged();
    }
}

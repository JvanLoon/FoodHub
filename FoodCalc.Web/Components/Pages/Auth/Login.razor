@page "/login"
@layout Layout.LoginLayout
@using FoodCalc.Web.Components.Services.Auth
@using Microsoft.AspNetCore.Components.Forms
@inject LoginService LoginService
@inject NavigationManager Navigation
@inject AuthStateService AuthStateService
@inject MessageService MessageService

<PageTitle>Login</PageTitle>

<div class="auth-card">
    <div class="auth-card__brand">
        <i class="bi bi-basket2-fill" aria-hidden="true"></i>
        <span>FoodHub</span>
    </div>
    <h3 class="auth-card__title">Welcome back</h3>
    <EditForm Model="loginModel" OnValidSubmit="HandleLogin" FormName="login-form">
        <DataAnnotationsValidator />
        <ValidationSummary class="mb-3" />
        <TextField Label="Email" Placeholder="Enter your email" Autocomplete="username" @bind-Value="loginModel.Email" />
        <TextField Label="Password" Type="password" Placeholder="Enter your password" Autocomplete="current-password" @bind-Value="loginModel.Password" />
        <AppButton Type="submit" Icon="box-arrow-in-right" CssClass="w-100">Login</AppButton>
    </EditForm>
    <div class="auth-card__alt">
        <a href="/register">Create an account</a>
    </div>
</div>

@code {
    private LoginDto loginModel = new();

    private async Task HandleLogin()
    {
        var response = await LoginService.LoginAsync(loginModel);

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<AuthResponseDto>();
            if (result?.Token == null)
            {
                await MessageService.ShowMessageAsync("Login failed: invalid server response.", true);
                return;
            }
            await AuthStateService.SignInAsync(result.Token);
            Navigation.NavigateTo("/");
        }
        else
        {
            await MessageService.ShowMessageAsync("Failed to login. Invalid email or password.", true);
        }
    }
}

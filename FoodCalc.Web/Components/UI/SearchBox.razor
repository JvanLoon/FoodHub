@* Debounced, clearable search input. Bind with @bind-Value; ValueChanged fires
   after DebounceMs of typing silence so callers can query the API directly. *@
@implements IDisposable

<div class="fh-search @CssClass">
    <i class="bi bi-search fh-search__icon" aria-hidden="true"></i>
    <input type="text"
           class="form-control"
           placeholder="@Placeholder"
           aria-label="@Placeholder"
           value="@Value"
           @oninput="HandleInput" />
    @if (!string.IsNullOrEmpty(Value))
    {
        <button type="button" class="fh-search__clear" aria-label="Clear search" @onclick="ClearAsync">
            <i class="bi bi-x-lg" aria-hidden="true"></i>
        </button>
    }
</div>

@code {
    [Parameter]
    public string Value { get; set; } = string.Empty;
    [Parameter]
    public EventCallback<string> ValueChanged { get; set; }
    [Parameter]
    public string Placeholder { get; set; } = "Search...";
    [Parameter]
    public int DebounceMs { get; set; } = 300;
    [Parameter]
    public string? CssClass { get; set; }

    private CancellationTokenSource _cts = new();

    private async Task HandleInput(ChangeEventArgs e)
    {
        var text = e.Value?.ToString() ?? string.Empty;
        Value = text;

        _cts.Cancel();
        _cts.Dispose();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        if (DebounceMs > 0)
        {
            try
            {
                await Task.Delay(DebounceMs, token);
            }
            catch (OperationCanceledException)
            {
                return;
            }
        }

        await ValueChanged.InvokeAsync(text);
    }

    private async Task ClearAsync()
    {
        _cts.Cancel();
        Value = string.Empty;
        await ValueChanged.InvokeAsync(string.Empty);
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}

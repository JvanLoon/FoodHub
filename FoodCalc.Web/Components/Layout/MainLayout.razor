@using FoodCalc.Web.Components.Services.Auth
@inherits LayoutComponentBase
@implements IDisposable
@inject AuthTokenService AuthTokenService
@inject MessageService MessageService
@inject NavigationManager Navigation

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="auth-bar">
            @if (!string.IsNullOrEmpty(userEmail))
            {
                <div class="auth-info">
                    <span class="user-email">@userEmail</span>
                    <button class="logout-btn" @onclick="Logout">Logout</button>
                </div>
            }
            else
            {
                <div class="auth-info">
                    <button class="login-btn" @onclick='() => Navigation.NavigateTo("/login")'>Login</button>
                </div>
            }
        </div>
        <article class="content px-4">
            @* <FoodCalc.Web.Components.Shared.MessageBox /> *@
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code{
    private string? userEmail;

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;
        try
        {
            if (await AuthTokenService.IsTokenExpiredAsync())
            {
                await Logout();
            }
        }
        catch (Exception ex)
        {
            await MessageService.ShowMessageAsync(ex.Message, true, 20000);
            StateHasChanged();
        }
        await RefreshEmailAsync();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _ = InvokeAsync(HandleLocationChangedAsync);
    }

    private async Task HandleLocationChangedAsync()
    {
        try
        {
            if (string.IsNullOrEmpty(userEmail))
            {
                await RefreshEmailAsync();
            }
        }
        catch (Exception ex)
        {
            await MessageService.ShowMessageAsync(ex.Message, true, 20000);
        }
    }

    private async Task RefreshEmailAsync()
    {
        userEmail = await AuthTokenService.GetEmailAsync() ?? string.Empty;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private async Task Logout()
    {
        await AuthTokenService.RemoveTokenAsync(); // Clear the cookie
        await RefreshEmailAsync(); // Clear the email and update UI
        Navigation.NavigateTo("/login");
    }
}

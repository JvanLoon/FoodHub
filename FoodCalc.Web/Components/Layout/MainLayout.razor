@using FoodCalc.Web.Components.Services.Auth
@inherits LayoutComponentBase
@implements IDisposable
@inject AuthStateService AuthStateService
@inject MessageService MessageService
@inject NavigationManager Navigation

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="auth-bar">
            @if (!string.IsNullOrEmpty(userEmail))
            {
                <div class="auth-info">
                    <span class="user-email">@userEmail</span>
                    <button class="logout-btn" @onclick="Logout">Logout</button>
                </div>
            }
            else
            {
                <div class="auth-info">
                    <button class="login-btn" @onclick='() => Navigation.NavigateTo("/login")'>Login</button>
                </div>
            }
        </div>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private string? userEmail;

    protected override async Task OnInitializedAsync()
    {
        AuthStateService.OnAuthStateChanged += HandleAuthStateChangedAsync;
        try
        {
            if (!await AuthStateService.IsLoggedInAsync())
            {
                await AuthStateService.SignOutAsync();
                Navigation.NavigateTo("/login");
                return;
            }
            userEmail = await AuthStateService.GetEmailAsync();
        }
        catch (Exception ex)
        {
            await MessageService.ShowMessageAsync(ex.Message, true, 20000);
        }
    }

    private async Task HandleAuthStateChangedAsync()
    {
        userEmail = await AuthStateService.IsLoggedInAsync()
            ? await AuthStateService.GetEmailAsync()
            : null;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AuthStateService.OnAuthStateChanged -= HandleAuthStateChangedAsync;
    }

    private async Task Logout()
    {
        await AuthStateService.SignOutAsync();
        Navigation.NavigateTo("/login");
    }
}

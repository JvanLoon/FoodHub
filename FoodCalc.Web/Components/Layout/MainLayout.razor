@inherits LayoutComponentBase
@inject AuthTokenService AuthTokenService
@inject NavigationManager Navigation

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="nav-item px-3">
            @if (!string.IsNullOrEmpty(userEmail))
            {
                <span class="nav-link">@userEmail</span>
                <button class="nav-link" @onclick="Logout">Logout</button>
            }
            else
            {
                <a class="nav-link" href="/login">Login</a>
            }
        </div>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code{
     private string? userEmail;

    protected override async Task OnInitializedAsync()
    {
        if (await AuthTokenService.IsTokenExpiredAsync())
        {
            await AuthTokenService.RemoveTokenAsync();
            Navigation.NavigateTo("/login");
        }
        
        userEmail = await AuthTokenService.GetEmailAsync();
    }

    private async Task Logout()
    {
        await AuthTokenService.RemoveTokenAsync(); // Clear the cookie
        Navigation.NavigateTo("/login");
    }
}
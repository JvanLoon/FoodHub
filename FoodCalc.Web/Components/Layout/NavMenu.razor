@using FoodCalc.Web.Components.Services.Auth
@inject AuthTokenService AuthTokenService

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">FoodHub</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        @if (isLoggedIn)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <span class="bi bi-house-door-fill" aria-hidden="true"></span> Home
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/recipes/create">
                    <span class="bi bi-list-nested" aria-hidden="true"></span> Add recipe
	            </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/ingredients">
                    <span class="bi bi-list-nested" aria-hidden="true"></span> Edit Ingredients
                </NavLink>
            </div>
            @if (isAdmin)
            {
                <div class="nav-item px-3">
                    
                        <NavLink class="nav-link" href="/admin">
                            <span class="bi bi-gear" aria-hidden="true"></span> Admin
                        </NavLink>
                </div>
            }
        }
    </nav>
</div>

@code {
    private bool isAdmin = false;
    private bool isLoggedIn = false;
    private string userEmail = "";

    private bool showMessage = false;
    private bool IsError = false;
    private string _message = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var roles = await AuthTokenService.GetRolesAsync();
                isLoggedIn = roles.Any();
                isAdmin = roles?.Contains("Admin") == true;
                StateHasChanged();
                // TODO: Replace with actual role check from auth state
                // isAdmin = await AuthService.IsUserInRoleAsync("Admin");
                // TODO: Replace with actual login state and email from auth state
                // isLoggedIn = await AuthService.IsLoggedInAsync();
                // userEmail = await AuthService.GetUserEmailAsync();
            }
            catch (Exception ex)
            {
                ShowMessage(ex.Message, true, 20000);
                StateHasChanged();
            }
        }
    }

    async Task ShowMessage(string message, bool isError, int timeInMs = 2000)
    {
        _message = message;
        IsError = isError;

        showMessage = true;
        StateHasChanged();

        await Task.Delay(timeInMs);

        showMessage = false;
        _message = string.Empty;
        IsError = false;
        StateHasChanged();
    }
}

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">FoodHub</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/recipes/create">
                <span class="bi bi-list-nested" aria-hidden="true"></span> Add recipe
	        </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/ingredients">
                <span class="bi bi-list-nested" aria-hidden="true"></span> Edit Ingredients
            </NavLink>
        </div>
        <div class="nav-item px-3">
            @if (isAdmin)
            {
                <NavLink class="nav-link" href="/admin">
                    <span class="bi bi-gear" aria-hidden="true"></span> Admin
                </NavLink>
            }
        </div>
        <div class="nav-item px-3">
            @if (isLoggedIn)
            {
                <span class="nav-link">@userEmail</span>
            }
            else
            {
                <NavLink class="nav-link" href="/login">
                    <span class="bi bi-box-arrow-in-right" aria-hidden="true"></span> Login
                </NavLink>
            }
        </div>
    </nav>
</div>

@code {
    private bool isAdmin = false;
    private bool isLoggedIn = false;
    private string userEmail = "";


@using FoodCalc.Web.Components.Services.Auth
@implements IDisposable
@inject AuthStateService AuthStateService
@inject MessageService MessageService

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">FoodHub</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        @if (isLoggedIn)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <span class="bi bi-house-door-fill" aria-hidden="true"></span> Home
                </NavLink>
            </div>

            @if (isAdmin)
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/recipes/create">
                        <span class="bi bi-list-nested" aria-hidden="true"></span> Add recipe
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/ingredients">
                        <span class="bi bi-list-nested" aria-hidden="true"></span> Edit Ingredients
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/admin">
                        <span class="bi bi-gear" aria-hidden="true"></span> Admin
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/admin/dataimportexport" Match="NavLinkMatch.All">
                        <span class="bi bi-arrow-down-up" aria-hidden="true"></span> Import/Export
                    </NavLink>
                </div>
            }
            
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/usersettings">
                    <span class="bi bi-person" aria-hidden="true"></span> User Settings
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    private bool isAdmin;
    private bool isLoggedIn;

    protected override async Task OnInitializedAsync()
    {
        AuthStateService.OnAuthStateChanged += HandleAuthStateChangedAsync;
        await RefreshStateAsync();
    }

    private async Task HandleAuthStateChangedAsync()
    {
        await RefreshStateAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshStateAsync()
    {
        try
        {
            isLoggedIn = await AuthStateService.IsLoggedInAsync();
            isAdmin = isLoggedIn && await AuthStateService.IsAdminAsync();
        }
        catch (Exception ex)
        {
            await MessageService.ShowMessageAsync(ex.Message, true, 0);
        }
    }

    public void Dispose()
    {
        AuthStateService.OnAuthStateChanged -= HandleAuthStateChangedAsync;
    }
}

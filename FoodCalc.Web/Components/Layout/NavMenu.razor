@using FoodCalc.Web.Components.Services.Auth
@inject AuthTokenService AuthTokenService
@inject MessageService MessageService

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">FoodHub</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        @if (isLoggedIn || isAdmin)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <span class="bi bi-house-door-fill" aria-hidden="true"></span> Home
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/recipes/create">
                    <span class="bi bi-list-nested" aria-hidden="true"></span> Add recipe
	            </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/ingredients">
                    <span class="bi bi-list-nested" aria-hidden="true"></span> Edit Ingredients
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/usersettings">
                    <span class="bi bi-person" aria-hidden="true"></span> User Settings
                </NavLink>
            </div>

            @if (isAdmin)
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/admin">
                        <span class="bi bi-gear" aria-hidden="true"></span> Admin
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/admin/dataimportexport" Match="NavLinkMatch.All">
                        <span class="oi oi-data-transfer-download" aria-hidden="true"></span> Import/Export
                    </NavLink>
                </div>
            }
        }
    </nav>
    @* <FoodCalc.Web.Components.Shared.MessageBox /> *@
</div>

@code {
    private bool isAdmin = false;
    private bool isLoggedIn = false;
    private string userEmail = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var roles = await AuthTokenService.GetRolesAsync();
                isLoggedIn = roles.Any();
                isAdmin = roles?.Contains("Admin") == true;
                StateHasChanged();

                // TODO: Replace with actual role check from auth state
                // isAdmin = await AuthService.IsUserInRoleAsync("Admin");
                // TODO: Replace with actual login state and email from auth state
                // isLoggedIn = await AuthService.IsLoggedInAsync();
                // userEmail = await AuthService.GetUserEmailAsync();
            }
            catch (Exception ex)
            {
                await MessageService.ShowMessageAsync(ex.Message, true, 0);
            }
        }
    }
}

@inject MessageService MessageService
@implements IDisposable

@* @if (showMessage) *@
@* { *@
@*     <div class="message-box @(isError ? "error" : "info")"> *@
@*         @message *@
@*     </div> *@
@* } *@

@if (showMessage)
{
    <div class="alert @(isError ? "alert-danger" : "alert-success") mt-3">
        @message
    </div>
}

@code {
    private string message = string.Empty;
    private bool isError;
    private bool showMessage;
    private CancellationTokenSource _cts = new();

    protected override void OnInitialized()
    {
        MessageService.OnShowMessage += ShowMessage;
    }

    private async Task ShowMessage(string msg, bool error, int timeInMs, CancellationToken externalToken)
    {
        // Cancel any in-progress auto-hide timer before showing the new message
        await _cts.CancelAsync();
        _cts.Dispose();
        _cts = new CancellationTokenSource();

        message = msg;
        isError = error;
        showMessage = true;
        await InvokeAsync(StateHasChanged);

        if (timeInMs != 0)
        {
            using var linked = CancellationTokenSource.CreateLinkedTokenSource(_cts.Token, externalToken);
            try
            {
                await Task.Delay(timeInMs, linked.Token);
            }
            catch (OperationCanceledException)
            {
                return;
            }

            showMessage = false;
            message = string.Empty;
            isError = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
        MessageService.OnShowMessage -= ShowMessage;
    }
}

@* State-driven tabs (no Bootstrap JS). Usage:
   <TabSet><Tab Title="Users">...</Tab><Tab Title="Roles">...</Tab></TabSet> *@

<CascadingValue Value="this" IsFixed="true">
    <div class="fh-tabset">
        <div class="fh-tabset__bar" role="tablist">
            @foreach (var tab in _tabs)
            {
                <button type="button"
                        role="tab"
                        class="fh-tabset__tab @(tab == ActiveTab ? "fh-tabset__tab--active" : null)"
                        aria-selected="@(tab == ActiveTab)"
                        @onclick="() => Activate(tab)">
                    @if (!string.IsNullOrEmpty(tab.Icon))
                    {
                        <i class="bi bi-@tab.Icon" aria-hidden="true"></i>
                    }
                    @tab.Title
                </button>
            }
        </div>
        <div class="fh-tabset__panel" role="tabpanel">
            @ChildContent
        </div>
    </div>
</CascadingValue>

@code {
    [Parameter] 
    public RenderFragment? ChildContent { get; set; }

    private readonly List<Tab> _tabs = new();

    internal Tab? ActiveTab { get; private set; }

    internal void AddTab(Tab tab)
    {
        _tabs.Add(tab);
        ActiveTab ??= tab;
        StateHasChanged();
    }

    private void Activate(Tab tab)
    {
        ActiveTab = tab;
    }
}

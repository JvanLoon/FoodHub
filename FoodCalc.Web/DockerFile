# syntax=docker/dockerfile:1

# ---- Build stage ----
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# Copy every csproj first so `restore` is cached independently of source changes.
# Web -> (DTOs, ServiceDefaults)
COPY ["FoodCalc.Web/FoodCalc.Web.csproj", "FoodCalc.Web/"]
COPY ["FoodHub.DTOs/FoodHub.DTOs.csproj", "FoodHub.DTOs/"]
COPY ["FoodHub.ServiceDefaults/FoodHub.ServiceDefaults.csproj", "FoodHub.ServiceDefaults/"]

RUN dotnet restore "FoodCalc.Web/FoodCalc.Web.csproj"

# Copy the rest of the source and publish. NB: no --no-restore here — on .NET 10
# the framework static web assets (_framework/blazor.web.js) come from the
# restorable microsoft.aspnetcore.app.internal.assets package, and a csproj-only
# restore + --no-restore leaves them out of the publish. The earlier restore
# still warms the NuGet cache, so this re-restore is fast.
COPY . .
RUN dotnet publish "FoodCalc.Web/FoodCalc.Web.csproj" -c Release -o /app/publish

# ---- Runtime stage ----
FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS final
WORKDIR /app
COPY --from=build /app/publish .

EXPOSE 8080
ENV ASPNETCORE_URLS=http://+:8080
ENTRYPOINT ["dotnet", "FoodCalc.Web.dll"]

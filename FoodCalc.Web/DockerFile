# Build stage
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

# Copy .csproj files
COPY ["FoodCalc.Web/FoodCalc.Web.csproj", "FoodCalc.Web/"]
COPY ["FoodHub.DTOs/FoodHub.DTOs.csproj", "FoodHub.DTOs/"]
COPY ["FoodHub.ServiceDefaults/FoodHub.ServiceDefaults.csproj", "FoodHub.ServiceDefaults/"]

# Copy the rest of the source code
COPY . .

# Set working directory to the web project
WORKDIR /src/FoodCalc.Web

# Restore, build, and publish
RUN dotnet restore
RUN dotnet publish "FoodCalc.Web.csproj" -c Release -o /app/publish

# Runtime stage
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS final
WORKDIR /app
COPY --from=build /app/publish .
EXPOSE 443
ENV ASPNETCORE_URLS=http://+:443
ENTRYPOINT ["dotnet", "FoodCalc.Web.dll"]

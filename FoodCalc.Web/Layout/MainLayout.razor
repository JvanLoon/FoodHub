@inherits LayoutComponentBase
@implements IDisposable
@inject AuthStateService AuthStateService
@inject MessageService MessageService
@inject NavigationManager Navigation

<div class="page">
	<div class="sidebar">
		<NavMenu/>
	</div>

	<main>
		<header class="topbar">
			<div class="topbar__actions">
				<ThemeToggle/>
				@if (!string.IsNullOrEmpty(userEmail))
				{
					<span class="topbar__email fh-truncate" title="@userEmail">
                        <i class="bi bi-person-circle" aria-hidden="true"></i>
						@userEmail
                    </span>
					<AppButton Variant="ButtonVariant.OutlineSecondary" Size="ButtonSize.Small"
					           Icon="box-arrow-right" OnClick="Logout">Logout
					</AppButton>
				}
				else
				{
					<AppButton Variant="ButtonVariant.Primary" Size="ButtonSize.Small"
					           Icon="box-arrow-in-right" OnClick='() => Navigation.NavigateTo("/login")'>Login
					</AppButton>
				}
			</div>
		</header>
		<article class="content">
			<div class="content__inner">
				@Body
			</div>
		</article>
	</main>
</div>

<ToastHost/>

<div id="blazor-error-ui">
	An unhandled error has occurred.
	<a href="" class="reload">Reload</a>
	<a class="dismiss">🗙</a>
</div>

@code {
	private string? userEmail;

	protected override async Task OnInitializedAsync()
	{
		AuthStateService.OnAuthStateChanged += HandleAuthStateChangedAsync;
		try
		{
			if (!await AuthStateService.IsLoggedInAsync())
			{
				await AuthStateService.SignOutAsync();
				Navigation.NavigateTo("/login");
				return;
			}

			userEmail = await AuthStateService.GetEmailAsync();
		}
		catch (Exception ex) { MessageService.ShowMessage(ex.Message, true, 20000); }
	}

	private async Task HandleAuthStateChangedAsync()
	{
		userEmail = await AuthStateService.IsLoggedInAsync() ? await AuthStateService.GetEmailAsync() : null;
		await InvokeAsync(StateHasChanged);
	}

	public void Dispose() { AuthStateService.OnAuthStateChanged -= HandleAuthStateChangedAsync; }

	private async Task Logout()
	{
		await AuthStateService.SignOutAsync();
		Navigation.NavigateTo("/login");
	}

}
